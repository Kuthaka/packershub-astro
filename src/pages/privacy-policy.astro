---
// src/pages/privacy-policy.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CONTACT } from '../data/cities';
---

<BaseLayout
  title="Privacy Policy | PackersHub"
  description="PackersHub Privacy Policy — how we collect, use, and protect your personal data."
  canonical="https://packershub.in/privacy-policy/"
>
  <Header slot="header" />

  <section class="section bg-white">
    <div class="container max-w-3xl">
      <div class="mb-10 reveal">
        <div class="section-badge mb-4">Legal</div>
        <h1 class="font-display text-h1 text-warm-950 mb-3">Privacy Policy</h1>
        <p class="text-sm text-warm-400">Last updated: May 2026</p>
      </div>

      <div class="prose prose-warm max-w-none reveal">
        <h2>1. Information We Collect</h2>
        <p>PackersHub collects the following information when you use our website or services:</p>
        <ul>
          <li><strong>Contact information:</strong> Name, phone number, email address</li>
          <li><strong>Move details:</strong> Origin city, destination city, move type, property size, preferred date</li>
          <li><strong>Device information:</strong> Browser type, IP address, pages visited (via Google Analytics)</li>
        </ul>

        <h2>2. How We Use Your Information</h2>
        <p>We use collected information to:</p>
        <ul>
          <li>Provide moving quotations and service delivery</li>
          <li>Contact you regarding your relocation requirements</li>
          <li>Improve our website and services</li>
          <li>Send service updates and important communications</li>
        </ul>

        <h2>3. Data Sharing</h2>
        <p>PackersHub does not sell, trade, or rent your personal information to third parties. We may share data with:</p>
        <ul>
          <li>Service partners (moving crew, truck operators) only as needed for service delivery</li>
          <li>Analytics providers (Google Analytics) — anonymized data only</li>
          <li>Legal authorities — only when required by law</li>
        </ul>

        <h2>4. Data Security</h2>
        <p>We implement industry-standard security measures to protect your personal information. All form data is transmitted over HTTPS encryption.</p>

        <h2>5. Cookies</h2>
        <p>Our website uses cookies for analytics and functionality. You can disable cookies in your browser settings; however, some site features may not work properly.</p>

        <h2>6. Your Rights</h2>
        <p>You have the right to access, correct, or request deletion of your personal data. Contact us at {CONTACT.email} for any data-related requests.</p>

        <h2>7. Contact for Privacy</h2>
        <p>For privacy concerns, contact:<br/>
        <strong>PackersHub</strong><br/>
        BV Nagar, Nellore, AP 524004<br/>
        Phone: {CONTACT.phoneDisplay}<br/>
        Email: {CONTACT.email}</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
