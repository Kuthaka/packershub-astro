---
// src/pages/[slug].astro — Dynamic city pages for all 75 cities
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { cities, getCitiesByState, states, CONTACT, BUSINESS, type City } from '../data/cities';

export async function getStaticPaths() {
  return cities.map(city => ({
    params: { slug: city.slug },
    props: { city },
  }));
}

interface Props { city: City; }
const { city } = Astro.props;
const stateInfo = states[city.state];
const nearbyCities = getCitiesByState(city.state).filter(c => c.slug !== city.slug).slice(0, 6);

const services = [
  { icon: '🏠', title: `Home Shifting in ${city.name}`, desc: `Complete household relocation service in ${city.name} with expert packing, safe transit, and door delivery.` },
  { icon: '🏢', title: `Office Relocation in ${city.name}`, desc: `Seamless corporate shifting with zero downtime. IT equipment, furniture, and assets — all handled professionally.` },
  { icon: '🚗', title: `Car Transport from ${city.name}`, desc: `Safe enclosed/open carrier transport for all vehicle types from ${city.name} to any destination.` },
  { icon: '🏍️', title: `Bike Transport in ${city.name}`, desc: `Safe two-wheeler shifting with proper fastening, packing, and insurance coverage.` },
  { icon: '📦', title: `Packing Services in ${city.name}`, desc: `Professional packing using international-grade materials — bubble wrap, foam, corrugated boxes, wooden crates.` },
  { icon: '🏭', title: `Warehouse Storage in ${city.name}`, desc: `24/7 secured climate-controlled storage with CCTV, fire protection, and pest control.` },
];

// Schema for city page
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['MovingCompany', 'LocalBusiness'],
  name: `PackersHub - Packers and Movers in ${city.name}`,
  url: `https://packershub.in/${city.slug}/`,
  telephone: CONTACT.phone,
  email: CONTACT.email,
  description: city.metaDescription,
  address: {
    '@type': 'PostalAddress',
    addressLocality: city.name,
    addressRegion: stateInfo.name,
    addressCountry: 'IN',
  },
  geo: { '@type': 'GeoCoordinates', latitude: city.lat, longitude: city.lng },
  areaServed: {
    '@type': 'City',
    name: city.name,
    containedInPlace: { '@type': 'State', name: stateInfo.name },
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '850',
    bestRating: '5',
  },
  priceRange: '₹₹',
  openingHoursSpecification: [{ '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'], opens: '06:00', closes: '22:00' }],
  sameAs: ['https://packershub.in'],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: city.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbs = [
  { name: stateInfo.name, url: `https://packershub.in/${stateInfo.slug}/` },
  { name: `Packers Movers ${city.name}`, url: `https://packershub.in/${city.slug}/` },
];
---

<BaseLayout
  title={city.metaTitle}
  description={city.metaDescription}
  canonical={`https://packershub.in/${city.slug}/`}
  schema={[localBusinessSchema, faqSchema]}
  cityName={city.name}
  stateName={stateInfo.name}
  breadcrumbs={breadcrumbs}
>
  <Header slot="header" />

  <!-- Breadcrumb -->
  <nav class="bg-warm-50 border-b border-warm-100 py-3" aria-label="Breadcrumb">
    <div class="container">
      <ol class="flex items-center gap-2 text-xs text-warm-500 flex-wrap">
        <li><a href="/" class="hover:text-brand-600">Home</a></li>
        <li class="text-warm-300">›</li>
        <li><a href={`/${stateInfo.slug}/`} class="hover:text-brand-600">{stateInfo.name}</a></li>
        <li class="text-warm-300">›</li>
        <li class="text-warm-800 font-medium">Packers Movers {city.name}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-hero-gradient relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="absolute -top-20 right-0 w-80 h-80 bg-brand-100/50 rounded-full blur-3xl"></div>

    <div class="container relative">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <!-- Rating badge -->
          <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-full px-4 py-1.5 text-xs font-semibold text-amber-700 mb-5 reveal">
            <span>⭐ 4.8/5</span>
            <span class="text-amber-400">|</span>
            <span>850+ Reviews in {city.name}</span>
          </div>

          <h1 class="font-display text-h1 text-warm-950 mb-5 reveal reveal-delay-1">
            {city.h1}
          </h1>

          <p class="text-body-lg text-warm-600 mb-6 reveal reveal-delay-2 max-w-xl text-pretty">
            {city.intro}
          </p>

          <!-- Highlights -->
          <div class="grid grid-cols-2 gap-2 mb-8 reveal reveal-delay-3">
            {city.highlights.map(h => (
              <div class="flex items-center gap-2 text-sm text-warm-700">
                <div class="w-5 h-5 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-brand-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                </div>
                {h}
              </div>
            ))}
          </div>

          <div class="flex flex-wrap gap-3 reveal reveal-delay-4">
            <a href="/get-quote/" class="btn-primary-lg">Get Free Quote</a>
            <a href={CONTACT.whatsappLink(`Hi! I need packers and movers in ${city.name}.`)} target="_blank" rel="noopener" class="btn-whatsapp px-7 py-4 text-base rounded-2xl">WhatsApp Us</a>
            <a href="tel:+917731074075" class="btn-outline px-7 py-4 text-base rounded-2xl">📞 Call Now</a>
          </div>
        </div>

        <!-- Quick info card -->
        <div class="card p-7 reveal reveal-delay-2">
          <h2 class="font-semibold text-lg text-warm-950 mb-5">Quick Info — {city.name}</h2>
          <div class="space-y-4 text-sm">
            {[
              { label: 'City', value: city.name },
              { label: 'State', value: stateInfo.name },
              { label: 'District', value: city.district },
              { label: 'Population', value: city.population },
              { label: 'ServiceArea', value: `${city.name} & ${city.nearbyAreas.slice(0,3).join(', ')}` },
              { label: 'Available', value: '7 Days • 6 AM – 10 PM' },
              { label: 'Quote', value: 'Free Estimate in 60 sec' },
            ].map(r => (
              <div class="flex items-start gap-3 py-2 border-b border-warm-100 last:border-0">
                <span class="text-warm-400 w-24 flex-shrink-0">{r.label}</span>
                <span class="text-warm-900 font-medium">{r.value}</span>
              </div>
            ))}
          </div>
          <a href="tel:+917731074075" class="btn-primary w-full mt-5 rounded-xl py-3.5">
            📞 Call +91 77310 74075
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services in City -->
  <section class="section bg-warm-50">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <div class="section-badge mb-4">Services in {city.name}</div>
        <h2 class="section-title mb-4">What We Offer in {city.name}</h2>
        <p class="section-subtitle">Comprehensive relocation services tailored for {city.name} residents and businesses.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((s, i) => (
          <div class={`card p-6 reveal reveal-delay-${i+1}`}>
            <div class="text-3xl mb-4">{s.icon}</div>
            <h3 class="font-semibold text-warm-950 mb-2">{s.title}</h3>
            <p class="text-sm text-warm-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="container max-w-3xl">
      <div class="text-center mb-10 reveal">
        <div class="section-badge mb-4">FAQ</div>
        <h2 class="section-title mb-4">Packers & Movers {city.name} — FAQs</h2>
      </div>
      <div class="space-y-3">
        {city.faqs.map((faq, i) => (
          <details class={`group card p-0 reveal reveal-delay-${i+1}`}>
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
              <h3 class="font-semibold text-warm-950 text-sm">{faq.q}</h3>
              <svg class="w-5 h-5 text-brand-500 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-sm text-warm-600 leading-relaxed border-t border-warm-100 pt-4">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Nearby cities -->
  <section class="section-sm bg-brand-50">
    <div class="container">
      <h2 class="font-display text-h3 text-warm-950 mb-6 reveal">Nearby Cities We Serve in {stateInfo.name}</h2>
      <div class="flex flex-wrap gap-3">
        {nearbyCities.map((c, i) => (
          <a href={`/${c.slug}/`} class={`card px-5 py-3 hover:bg-brand-500 hover:text-white hover:border-brand-500 transition-all group reveal reveal-delay-${i+1}`}>
            <span class="font-medium text-sm group-hover:text-white text-warm-800">{c.name}</span>
            <span class="text-xs text-warm-400 group-hover:text-brand-100 ml-2">→</span>
          </a>
        ))}
        <a href={`/${stateInfo.slug}/`} class="btn-outline px-5 py-3 text-sm rounded-xl">View All {stateInfo.name} Cities →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm bg-brand-500 text-white">
    <div class="container text-center reveal">
      <h2 class="font-display text-h2 mb-4">Move with Confidence in {city.name}</h2>
      <p class="text-brand-100 text-body-lg mb-8 max-w-xl mx-auto">Get a free, no-obligation quote for your move in {city.name}. Our team is ready to help.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/get-quote/" class="btn-white px-8 py-4 text-base rounded-2xl">Get Free Quote</a>
        <a href={CONTACT.whatsappLink(`Hi! I need shifting in ${city.name}.`)} target="_blank" rel="noopener" class="border-2 border-white/40 text-white hover:bg-white/10 px-8 py-4 text-base rounded-2xl font-semibold transition-all inline-flex items-center gap-2">📱 WhatsApp</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
