---
// src/pages/index.astro — PackersHub Premium Homepage (V4)
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT } from '../data/cities';

// Meta from the new HTML
const pageTitle = "PackersHub — #1 Packers & Movers in South India | 75 Cities | IBA Approved";
const pageDescription = "PackersHub: South India's most trusted packers & movers across 75+ cities in AP, Telangana, Tamil Nadu, Karnataka & Kerala. IBA approved · GPS tracked · Zero damage guarantee · 15+ years experience.";

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How much does PackersHub charge for household shifting?","acceptedAnswer":{"@type":"Answer","text":"PackersHub starts from ₹3,999 for 1BHK household shifting. Final price depends on distance, home size, floor, and extra services. Call +917731074075 for a free fixed-price quote with no hidden charges."}},
    {"@type":"Question","name":"Is PackersHub IBA approved?","acceptedAnswer":{"@type":"Answer","text":"Yes. PackersHub is fully IBA (Indian Banks' Association) approved. This means all relocation claims with major Indian banks — SBI, HDFC, ICICI and more — are 100% valid with our invoice."}},
    {"@type":"Question","name":"Which cities does PackersHub serve?","acceptedAnswer":{"@type":"Answer","text":"PackersHub serves 75+ cities across 5 South Indian states: 20 cities in Andhra Pradesh, 14 in Telangana, 16 in Tamil Nadu, 15 in Karnataka, and 10 in Kerala. We also handle inter-state and pan-India moves."}},
    {"@type":"Question","name":"Does PackersHub offer GPS tracking?","acceptedAnswer":{"@type":"Answer","text":"Yes. Every truck has live GPS tracking. You receive a real-time WhatsApp tracking link the moment your goods are loaded, so you know exactly where your belongings are at all times."}},
    {"@type":"Question","name":"What is PackersHub's damage guarantee?","acceptedAnswer":{"@type":"Answer","text":"PackersHub offers a Zero Damage Guarantee backed by comprehensive transit insurance up to ₹10 lakhs per move. Damaged or lost items are replaced — no questions asked."}},
    {"@type":"Question","name":"How do I book PackersHub?","acceptedAnswer":{"@type":"Answer","text":"Call or WhatsApp +917731074075 any day 7AM–9PM. Our team surveys your home (in-person or virtually), gives you a fixed written quote, and confirms your move date — usually within 2 hours."}}
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schema={schemaFAQ}
>
  <!-- Custom Fonts for V4 -->
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Syne+Mono&display=swap" rel="stylesheet" slot="head">

  <!-- ═══════ NAVBAR ═══════ -->
  <nav class="nav" id="navbar">
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/logo.svg" alt="PackersHub Logo" class="old-logo" />
          <div>
            <div>PackersHub</div>
            <div class="logo-sub">EST. 2009</div>
          </div>
        </a>

        <div class="nav-links">
          <a href="/" class="nav-link">Home</a>
          <a href="#services" class="nav-link">Services</a>

          <div class="nav-drop-wrap">
            <a href="#coverage" class="nav-link has-drop">Cities</a>
            <div class="mega-drop">
              <div class="mega-cols">
                <div>
                  <div class="mega-col-title">Andhra Pradesh</div>
                  <a href="/cities/ap/packers-movers-nellore.html" class="mega-city-link">Nellore</a>
                  <a href="/cities/ap/packers-movers-visakhapatnam.html" class="mega-city-link">Visakhapatnam</a>
                  <a href="/cities/ap/packers-movers-vijayawada.html" class="mega-city-link">Vijayawada</a>
                  <a href="/cities/ap/packers-movers-tirupati.html" class="mega-city-link">Tirupati</a>
                  <a href="/cities/ap/packers-movers-guntur.html" class="mega-city-link">Guntur</a>
                  <a href="/cities/ap/packers-movers-rajahmundry.html" class="mega-city-link">Rajahmundry</a>
                </div>
                <div>
                  <div class="mega-col-title">Telangana</div>
                  <a href="/cities/ts/packers-movers-hyderabad.html" class="mega-city-link">Hyderabad</a>
                  <a href="/cities/ts/packers-movers-warangal.html" class="mega-city-link">Warangal</a>
                  <a href="/cities/ts/packers-movers-karimnagar.html" class="mega-city-link">Karimnagar</a>
                  <a href="/cities/ts/packers-movers-khammam.html" class="mega-city-link">Khammam</a>
                  <a href="/cities/ts/packers-movers-nizamabad.html" class="mega-city-link">Nizamabad</a>
                </div>
                <div>
                  <div class="mega-col-title">Tamil Nadu</div>
                  <a href="/cities/tn/packers-movers-chennai.html" class="mega-city-link">Chennai</a>
                  <a href="/cities/tn/packers-movers-coimbatore.html" class="mega-city-link">Coimbatore</a>
                  <a href="/cities/tn/packers-movers-madurai.html" class="mega-city-link">Madurai</a>
                  <a href="/cities/tn/packers-movers-salem.html" class="mega-city-link">Salem</a>
                  <a href="/cities/tn/packers-movers-trichy.html" class="mega-city-link">Trichy</a>
                </div>
                <div>
                  <div class="mega-col-title">Karnataka</div>
                  <a href="/cities/ka/packers-movers-bengaluru.html" class="mega-city-link">Bengaluru</a>
                  <a href="/cities/ka/packers-movers-mysuru.html" class="mega-city-link">Mysuru</a>
                  <a href="/cities/ka/packers-movers-mangaluru.html" class="mega-city-link">Mangaluru</a>
                  <a href="/cities/ka/packers-movers-hubballi.html" class="mega-city-link">Hubballi</a>
                </div>
                <div>
                  <div class="mega-col-title">Kerala</div>
                  <a href="/cities/kl/packers-movers-kochi.html" class="mega-city-link">Kochi</a>
                  <a href="/cities/kl/packers-movers-thiruvananthapuram.html" class="mega-city-link">Trivandrum</a>
                  <a href="/cities/kl/packers-movers-kozhikode.html" class="mega-city-link">Kozhikode</a>
                  <a href="/cities/kl/packers-movers-thrissur.html" class="mega-city-link">Thrissur</a>
                </div>
              </div>
            </div>
          </div>

          <a href="/states/packers-movers-andhra-pradesh.html" class="nav-link">AP</a>
          <a href="/blog/" class="nav-link">Blog</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/contact/" class="nav-link">Contact</a>
          <a href="#faq" class="nav-link">FAQ</a>
        </div>

        <div class="nav-cta">
          <a href="tel:+917731074075" class="nav-phone">
            <span class="nav-phone-dot"></span>
            +91 77310 74075
          </a>
          <a href="#quote" class="btn btn-amber btn-sm">Free Quote</a>
          <button class="hamburger" id="hamburger-btn" aria-label="Menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div class="mobile-nav" id="mobileNav">
    <div class="mobile-nav-inner">
      <a href="/" class="mobile-nav-link">Home</a>
      <a href="#services" class="mobile-nav-link mobile-close">Services</a>
      <a href="#coverage" class="mobile-nav-link mobile-close">Cities</a>
      <a href="/blog/" class="mobile-nav-link">Blog</a>
      <a href="/about/" class="mobile-nav-link">About</a>
      <a href="/contact/" class="mobile-nav-link">Contact</a>
      <a href="#faq" class="mobile-nav-link mobile-close">FAQ</a>
      <div style="margin-top:32px;display:flex;flex-direction:column;gap:12px">
        <a href="tel:+917731074075" class="btn btn-primary btn-lg">📞 Call Us Now</a>
        <a href={CONTACT.whatsappLink()} class="btn btn-amber btn-lg">💬 WhatsApp</a>
      </div>
    </div>
  </div>

  <!-- ═══════ HERO ═══════ -->
  <section class="hero" id="home">
    <!-- Hero Background Image integration -->
    <div class="hero-image-bg">
      <img src="/images/main.jpg" alt="PackersHub Moving Services" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-bg">
      <div class="hero-bg-grid"></div>
      <div class="hero-shape-1"></div>
      <div class="hero-shape-2"></div>
    </div>

    <div class="container">
      <div class="hero-inner">
        <!-- Left -->
        <div class="hero-lhs">
          <div class="hero-eyebrow">
            <span class="hero-eyebrow-dot"></span>
            South India's #1 Verified Movers
          </div>

          <h1 class="hero-title">
            Move <em>Anywhere</em><br>
            Across South India<br>
            <span class="accent-amber">Safely. Swiftly.</span>
          </h1>

          <p class="hero-desc">
            From Nellore to Kochi, Hyderabad to Chennai — <strong>PackersHub</strong> delivers zero-damage guaranteed relocation across <strong>75 cities in 5 states.</strong> IBA approved. GPS tracked. 15+ years of trusted moves.
          </p>

          <div class="hero-trust">
            <span class="trust-badge green-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              IBA Approved
            </span>
            <span class="trust-badge amber-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              GPS Tracked
            </span>
            <span class="trust-badge green-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Zero Damage Guarantee
            </span>
            <span class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" color="#1A56DB"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
              75+ Cities
            </span>
          </div>

          <!-- Mobile Hero Image -->
          <div class="hero-mobile-image">
            <img src="/images/main.jpg" alt="PackersHub Moving Services" />
          </div>

          <div class="hero-cta">
            <a href={CONTACT.whatsappLink('Hi PackersHub! I need a free quote for moving.')} class="btn btn-amber btn-lg" target="_blank" rel="noopener">
              💬 WhatsApp Free Quote
            </a>
            <a href="tel:+917731074075" class="btn btn-outline btn-lg">
              📞 +91 77310 74075
            </a>
          </div>

          <div class="hero-stats">
            <div class="stat-cell">
              <div class="stat-num" data-target="50000">0<span class="plus">+</span></div>
              <div class="stat-label">Happy Moves</div>
            </div>
            <div class="stat-cell">
              <div class="stat-num" data-target="75">0<span class="plus">+</span></div>
              <div class="stat-label">Cities Covered</div>
            </div>
            <div class="stat-cell">
              <div class="stat-num" data-target="15">0<span class="plus">+</span></div>
              <div class="stat-label">Years Experience</div>
            </div>
            <div class="stat-cell">
              <div class="stat-num">4.9<span class="plus">★</span></div>
              <div class="stat-label">Google Rating</div>
            </div>
          </div>
        </div>

        <!-- Right - Quote Card -->
        <div class="hero-rhs" id="quote">
          <div class="quote-card">
            <div class="quote-card-label">Instant Estimate</div>
            <h2 class="quote-card-title">Get Your <em>Free</em> Moving Quote</h2>

            <form action="/get-quote/" method="GET" id="quoteForm">
              <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-input" placeholder="Your full name" required>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Moving From</label>
                  <input type="text" name="from" class="form-input" placeholder="City you're leaving" autocomplete="off" required>
                </div>
                <div class="form-group">
                  <label class="form-label">Moving To</label>
                  <input type="text" name="to" class="form-input" placeholder="Destination city" autocomplete="off" required>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Floor From</label>
                  <select name="floor_from" class="form-input form-select">
                    <option value="">Select floor</option>
                    <option>Ground Floor</option>
                    <option>1st Floor</option>
                    <option>2nd Floor</option>
                    <option>3rd Floor</option>
                    <option>4th Floor</option>
                    <option>5th+ Floor</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Floor To</label>
                  <select name="floor_to" class="form-input form-select">
                    <option value="">Select floor</option>
                    <option>Ground Floor</option>
                    <option>1st Floor</option>
                    <option>2nd Floor</option>
                    <option>3rd Floor</option>
                    <option>4th Floor</option>
                    <option>5th+ Floor</option>
                  </select>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Home Size</label>
                  <select name="size" class="form-input form-select">
                    <option value="">Select size</option>
                    <option>1 BHK</option>
                    <option>2 BHK</option>
                    <option>3 BHK</option>
                    <option>4 BHK+</option>
                    <option>Office / Shop</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Move Date</label>
                  <input type="date" name="date" class="form-input">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Your Phone</label>
                <input type="tel" name="phone" class="form-input" placeholder="+91 XXXXX XXXXX" required>
              </div>

              <button type="submit" class="btn btn-primary form-submit">
                Get Free Quote Now →
              </button>
            </form>

            <div class="quote-rating">
              <div class="stars">
                <span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span>
              </div>
              <div class="rating-text">
                <strong>4.9/5</strong> from 4,820+ verified reviews
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ TRUST BAR ═══════ -->
  <div class="trust-bar">
    <div class="marquee-track">
      <div class="marquee-item"><strong>IBA Approved</strong> Mover <span class="marquee-sep">·</span></div>
      <div class="marquee-item">GPS Tracked Trucks <span class="marquee-sep">·</span></div>
      <div class="marquee-item"><strong>Zero Damage</strong> Guarantee <span class="marquee-sep">·</span></div>
      <div class="marquee-item">₹10 Lakh Transit Insurance <span class="marquee-sep">·</span></div>
      <div class="marquee-item"><strong>75+ Cities</strong> Covered <span class="marquee-sep">·</span></div>
      <div class="marquee-item">4.9★ Google Rating <span class="marquee-sep">·</span></div>
      <div class="marquee-item">15+ Years Experience <span class="marquee-sep">·</span></div>
      <div class="marquee-item"><strong>50,000+</strong> Happy Families <span class="marquee-sep">·</span></div>
      <div class="marquee-item">Fixed Price — <strong>No Hidden Fees</strong> <span class="marquee-sep">·</span></div>
      <div class="marquee-item">7AM–9PM Support <span class="marquee-sep">·</span></div>
      <!-- duplicate for seamless loop -->
      <div class="marquee-item"><strong>IBA Approved</strong> Mover <span class="marquee-sep">·</span></div>
      <div class="marquee-item">GPS Tracked Trucks <span class="marquee-sep">·</span></div>
      <div class="marquee-item"><strong>Zero Damage</strong> Guarantee <span class="marquee-sep">·</span></div>
      <div class="marquee-item">₹10 Lakh Transit Insurance <span class="marquee-sep">·</span></div>
      <div class="marquee-item"><strong>75+ Cities</strong> Covered <span class="marquee-sep">·</span></div>
      <div class="marquee-item">4.9★ Google Rating <span class="marquee-sep">·</span></div>
      <div class="marquee-item">15+ Years Experience <span class="marquee-sep">·</span></div>
      <div class="marquee-item"><strong>50,000+</strong> Happy Families <span class="marquee-sep">·</span></div>
      <div class="marquee-item">Fixed Price — <strong>No Hidden Fees</strong> <span class="marquee-sep">·</span></div>
      <div class="marquee-item">7AM–9PM Support <span class="marquee-sep">·</span></div>
    </div>
  </div>

  <!-- ═══════ SERVICES ═══════ -->
  <section class="services" id="services">
    <div class="container">
      <div class="services-header">
        <div>
          <div class="label">What We Do</div>
          <h2 class="section-title">Complete <em>Relocation</em><br>Services</h2>
          <p class="section-subtitle">From packing a single room to relocating a corporate office — we handle every move with military-grade precision and five-star care.</p>
        </div>
        <a href="#quote" class="btn btn-amber">Book Any Service →</a>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🏠</div>
          <h3 class="service-name">Household Shifting</h3>
          <p class="service-desc">Complete home relocation with premium packing materials, trained crew, and GPS-tracked delivery. Every item insured up to ₹10 lakhs.</p>
          <div class="service-price">Starting from <strong>₹3,999</strong></div>
          <div class="service-arrow">Book Now →</div>
        </div>
        <div class="service-card">
          <div class="service-icon">🏢</div>
          <h3 class="service-name">Office Relocation</h3>
          <p class="service-desc">Minimal downtime office moves with IT equipment handling, modular furniture dismantling, and weekend scheduling available.</p>
          <div class="service-price">Starting from <strong>₹8,999</strong></div>
          <div class="service-arrow">Book Now →</div>
        </div>
        <div class="service-card">
          <div class="service-icon">🚗</div>
          <h3 class="service-name">Car Transport</h3>
          <p class="service-desc">Door-to-door enclosed carrier transport for your vehicle. GPS tracked, fully insured, driver-less transit for zero wear on your car.</p>
          <div class="service-price">Starting from <strong>₹4,999</strong></div>
          <div class="service-arrow">Book Now →</div>
        </div>
        <div class="service-card">
          <div class="service-icon">🛵</div>
          <h3 class="service-name">Bike Transport</h3>
          <p class="service-desc">Secure two-wheeler transport in dedicated bike carriers. Your bike is wrapped, strapped and delivered in showroom condition.</p>
          <div class="service-price">Starting from <strong>₹1,999</strong></div>
          <div class="service-arrow">Book Now →</div>
        </div>
        <div class="service-card">
          <div class="service-icon">📦</div>
          <h3 class="service-name">Packing Only</h3>
          <p class="service-desc">Expert packing using bubble wrap, foam, mirror cartons and double-walled boxes. Ideal for DIY movers who want professional packing.</p>
          <div class="service-price">Starting from <strong>₹999</strong></div>
          <div class="service-arrow">Book Now →</div>
        </div>
        <div class="service-card">
          <div class="service-icon">🏪</div>
          <h3 class="service-name">Warehouse Storage</h3>
          <p class="service-desc">Clean, CCTV-monitored, climate-controlled storage units. Perfect for between-move gaps, renovation periods or business inventory.</p>
          <div class="service-price">Starting from <strong>₹499/mo</strong></div>
          <div class="service-arrow">Book Now →</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ HOW IT WORKS ═══════ -->
  <section class="how" id="how">
    <div class="container">
      <div class="how-inner">
        <div>
          <div class="label">Simple Process</div>
          <h2 class="section-title">Your Move in<br><em>6 Easy Steps</em></h2>
          <p class="section-subtitle" style="margin-bottom:40px">We've perfected the relocation process over 15 years so you don't have to worry about a single thing.</p>

          <div class="steps">
            <div class="step">
              <div class="step-num">01</div>
              <div class="step-content">
                <div class="step-title">Call or WhatsApp Us</div>
                <div class="step-desc">Reach our relocation expert at +91 77310 74075. We answer within 60 seconds, 7AM–9PM, every day.</div>
              </div>
            </div>
            <div class="step">
              <div class="step-num">02</div>
              <div class="step-content">
                <div class="step-title">Free Home Survey</div>
                <div class="step-desc">We visit your home (or video call) to assess items, floors, and packing requirements accurately.</div>
              </div>
            </div>
            <div class="step">
              <div class="step-num">03</div>
              <div class="step-content">
                <div class="step-title">Written Fixed Quote</div>
                <div class="step-desc">You receive an itemised written quote. No hidden charges — ever. Valid for 7 days.</div>
              </div>
            </div>
            <div class="step">
              <div class="step-num">04</div>
              <div class="step-content">
                <div class="step-title">Book Your Date</div>
                <div class="step-desc">Pay a small advance to lock your preferred move date. Instant confirmation sent to your phone.</div>
              </div>
            </div>
            <div class="step">
              <div class="step-num">05</div>
              <div class="step-content">
                <div class="step-title">Expert Packing Day</div>
                <div class="step-desc">Our trained crew arrives on time with premium materials. Live GPS tracking activates on loading.</div>
              </div>
            </div>
            <div class="step">
              <div class="step-num">06</div>
              <div class="step-content">
                <div class="step-title">Safe Delivery & Handover</div>
                <div class="step-desc">Goods delivered, unpacked, and placed exactly where you want. You sign off only when fully satisfied.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="how-visual">
          <h3 class="how-visual-title">Transparent Pricing</h3>
          <p class="how-visual-sub">Estimated rates — final quote after free survey</p>
          <table class="price-table">
            <thead>
              <tr>
                <th>Home Size</th>
                <th>Local (same city)</th>
                <th>South India</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>1 BHK</td><td>₹3,999–₹6,999</td><td>₹7,999–₹14,999</td></tr>
              <tr><td>2 BHK</td><td>₹5,999–₹9,999</td><td>₹12,999–₹22,999</td></tr>
              <tr><td>3 BHK</td><td>₹8,999–₹14,999</td><td>₹18,999–₹32,999</td></tr>
              <tr><td>4 BHK+</td><td>₹14,999+</td><td>₹28,999+</td></tr>
              <tr><td>Office</td><td>₹8,999+</td><td>₹18,999+</td></tr>
            </tbody>
          </table>
          <div class="price-note">
            <strong>✅ Fixed pricing — no surprises.</strong> Your written quote is your final bill. We include packing materials, labour, transport & GST invoice (valid for IBA claims).
