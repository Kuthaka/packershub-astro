---
// src/pages/about/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { CONTACT, BUSINESS } from '../../data/cities';

const team = [
  { name: 'Founder & CEO', role: 'Operations Head', initials: 'PH', desc: '15+ years in logistics and relocation industry across South India.' },
  { name: 'Operations Manager', role: 'Fleet & Crew', initials: 'OM', desc: 'Oversees 200+ packers and 50+ trucks across all 5 states.' },
  { name: 'Customer Success', role: 'Client Relations', initials: 'CS', desc: 'Ensures every move meets our 4.8★ quality standard.' },
];

const milestones = [
  { year: '2018', event: 'PackersHub founded in Nellore, AP. Started with 3 trucks and 10 cities.' },
  { year: '2020', event: 'Expanded to Telangana. Crossed 10,000 successful moves.' },
  { year: '2022', event: 'Launched Tamil Nadu & Karnataka operations. Fleet grew to 50+ trucks.' },
  { year: '2023', event: 'Added Kerala. Now serving 75 cities across South India.' },
  { year: '2024', event: 'Crossed 50,000 happy customers. Launched digital tracking platform.' },
  { year: '2026', event: 'Industry-leading 4.8★ rating with 12,500+ verified reviews.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  url: 'https://packershub.in/about/',
  mainEntity: {
    '@type': 'MovingCompany',
    name: 'PackersHub',
    foundingDate: '2018',
    foundingLocation: 'Nellore, Andhra Pradesh, India',
    numberOfEmployees: { '@type': 'QuantitativeValue', value: 200 },
    description: BUSINESS.description,
  },
};
---

<BaseLayout
  title="About PackersHub | South India's Trusted Packers & Movers Since 2018"
  description="PackersHub was founded in 2018 in Nellore, AP. Learn about our mission, team, and journey to becoming South India's most trusted packers and movers serving 75 cities."
  canonical="https://packershub.in/about/"
  schema={schema}
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-hero-gradient py-20 md:py-28">
    <div class="container">
      <div class="max-w-3xl reveal">
        <div class="section-badge mb-5">Our Story</div>
        <h1 class="font-display text-h1 text-warm-950 mb-5">South India's Most Trusted Packers & Movers</h1>
        <p class="text-body-lg text-warm-600 text-pretty">Founded in 2018 in Nellore, Andhra Pradesh, PackersHub has grown from a 3-truck local mover to South India's most trusted relocation company — serving 75 cities across 5 states with a fleet of 50+ vehicles and 200+ trained professionals.</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-brand-500 text-white py-10">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[['50,000+','Happy Customers'],['75','Cities Served'],['7+','Years Experience'],['4.8★','Google Rating']].map(([n,l]) => (
          <div class="reveal">
            <div class="font-display text-3xl font-bold">{n}</div>
            <div class="text-brand-100 text-sm mt-1">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12">
        <div class="reveal">
          <div class="section-badge mb-5">Our Mission</div>
          <h2 class="section-title mb-5">Why We Exist</h2>
          <p class="text-warm-600 leading-relaxed mb-5">Moving is one of life's most stressful experiences. At PackersHub, our mission is simple: make every relocation stress-free, affordable, and safe for every family and business in South India.</p>
          <p class="text-warm-600 leading-relaxed mb-6">We believe in transparent pricing, professional service, and genuine care for your belongings — treating every item as if it were our own.</p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { icon: '🏆', title: 'Excellence', desc: '4.8★ average rating maintained consistently' },
              { icon: '🤝', title: 'Trust', desc: 'Fully licensed, insured, GST-compliant' },
              { icon: '💡', title: 'Innovation', desc: 'GPS tracking, digital invoicing, online quotes' },
              { icon: '❤️', title: 'Care', desc: 'Your goods handled with genuine care' },
            ].map(v => (
              <div class="bg-warm-50 rounded-xl p-4 border border-warm-100">
                <div class="text-2xl mb-2">{v.icon}</div>
                <div class="font-semibold text-warm-950 text-sm">{v.title}</div>
                <div class="text-xs text-warm-600 mt-1">{v.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Milestones -->
        <div class="reveal reveal-delay-2">
          <div class="section-badge mb-5">Our Journey</div>
          <h2 class="section-title mb-8">Milestones</h2>
          <div class="relative">
            <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-brand-200"></div>
            <div class="space-y-6">
              {milestones.map((m, i) => (
                <div class="flex gap-5 pl-12 relative">
                  <div class="absolute left-0 w-8 h-8 bg-brand-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 shadow-brand">{i+1}</div>
                  <div>
                    <div class="tag-brand text-xs mb-1">{m.year}</div>
                    <p class="text-sm text-warm-700 leading-relaxed">{m.event}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section bg-warm-50">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <div class="section-badge mb-4">Leadership</div>
        <h2 class="section-title mb-4">The Team Behind PackersHub</h2>
        <p class="section-subtitle">200+ trained professionals committed to your seamless relocation.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {team.map((t, i) => (
          <div class={`card p-7 text-center reveal reveal-delay-${i+1}`}>
            <div class="w-16 h-16 bg-brand-gradient rounded-2xl flex items-center justify-center text-white font-bold text-lg mx-auto mb-4 shadow-brand">{t.initials}</div>
            <div class="font-semibold text-warm-950 mb-0.5">{t.name}</div>
            <div class="tag-brand text-xs mb-3">{t.role}</div>
            <p class="text-sm text-warm-600 leading-relaxed">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section bg-white">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <div class="section-badge mb-4">Trust & Compliance</div>
        <h2 class="section-title mb-4">Our Certifications</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        {[
          { icon: '🏛️', title: 'GST Registered', desc: 'Valid GSTIN — Full tax invoice on every move' },
          { icon: '🛡️', title: 'IBA Approved', desc: 'Indian Banks\' Association approved mover' },
          { icon: '📋', title: 'ISO Certified', desc: 'ISO 9001:2015 Quality Management' },
          { icon: '🔐', title: 'Transit Insured', desc: 'Comprehensive goods transit insurance' },
        ].map((c, i) => (
          <div class={`card p-6 text-center reveal reveal-delay-${i+1}`}>
            <div class="text-3xl mb-3">{c.icon}</div>
            <div class="font-semibold text-warm-950 mb-1">{c.title}</div>
            <p class="text-xs text-warm-500">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm bg-brand-500 text-white">
    <div class="container text-center reveal">
      <h2 class="font-display text-h2 mb-4">Move with South India's Best</h2>
      <p class="text-brand-100 text-body-lg mb-8 max-w-xl mx-auto">50,000+ families have trusted PackersHub. You're next.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/get-quote/" class="btn-white px-8 py-4 text-base rounded-2xl">Get Free Quote</a>
        <a href="/contact/" class="border-2 border-white/40 text-white hover:bg-white/10 px-8 py-4 text-base rounded-2xl font-semibold transition-all">Contact Us</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
