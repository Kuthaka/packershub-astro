---
// src/pages/get-quote.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CONTACT, cities } from '../data/cities';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Get Free Moving Quote — PackersHub',
  url: 'https://packershub.in/get-quote/',
  mainEntity: { '@type': 'Organization', name: 'PackersHub', telephone: CONTACT.phone },
};
---

<BaseLayout
  title="Get Free Packers and Movers Quote | PackersHub — Instant Estimate"
  description="Get a free, instant moving quote from PackersHub. No hidden charges. Serving 75 cities across South India. Call +917731074075 or fill the form."
  canonical="https://packershub.in/get-quote/"
  schema={schema}
>
  <Header slot="header" />

  <section class="bg-hero-gradient py-16 md:py-20">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-start">

        <!-- Left -->
        <div class="reveal">
          <div class="section-badge mb-5">Free Estimate</div>
          <h1 class="font-display text-h1 text-warm-950 mb-5">Get Your Free Moving Quote</h1>
          <p class="text-body-lg text-warm-600 mb-8 text-pretty">Fill the form and receive a detailed, itemized quote within 30 minutes. No obligation, no hidden charges.</p>

          <div class="space-y-5 mb-8">
            {[
              { icon: '⚡', title: 'Instant Response', desc: 'Our team responds within 30 minutes during business hours.' },
              { icon: '💯', title: 'Accurate Estimate', desc: 'Detailed itemized quote based on your exact requirements.' },
              { icon: '🔒', title: 'No Commitment', desc: 'Getting a quote is completely free. No obligation to book.' },
              { icon: '🛡️', title: 'All-Inclusive Price', desc: 'Quote includes packing, labour, transport, and basic insurance.' },
            ].map(item => (
              <div class="flex items-start gap-4">
                <div class="text-2xl">{item.icon}</div>
                <div>
                  <div class="font-semibold text-warm-950">{item.title}</div>
                  <div class="text-sm text-warm-600">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>

          <!-- Contact alternatives -->
          <div class="bg-warm-50 rounded-2xl p-5 border border-warm-100">
            <p class="text-sm font-semibold text-warm-950 mb-3">Prefer to talk? Contact us directly:</p>
            <div class="space-y-2.5">
              <a href="tel:+917731074075" class="flex items-center gap-3 text-sm text-warm-700 hover:text-brand-600 transition-colors">
                <svg class="w-5 h-5 text-brand-500" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                <strong>+91 77310 74075</strong> — Primary
              </a>
              <a href={CONTACT.whatsappLink()} target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-warm-700 hover:text-green-600 transition-colors">
                <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <strong>WhatsApp</strong> — +91 77310 74075
              </a>
              <a href="mailto:info@packershub.in" class="flex items-center gap-3 text-sm text-warm-700 hover:text-brand-600 transition-colors">
                <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                info@packershub.in
              </a>
            </div>
          </div>
        </div>

        <!-- Quote Form -->
        <div class="card p-8 reveal reveal-delay-1">
          <h2 class="font-semibold text-xl text-warm-950 mb-6">Moving Details</h2>
          <form class="space-y-5" id="quote-form" action="https://formsubmit.co/info@packershub.in" method="POST">
            <input type="hidden" name="_subject" value="New Moving Quote Request — PackersHub" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://packershub.in/thank-you/" />

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="label">First Name *</label>
                <input type="text" name="first_name" class="input text-sm" placeholder="Ravi" required />
              </div>
              <div>
                <label class="label">Last Name *</label>
                <input type="text" name="last_name" class="input text-sm" placeholder="Kumar" required />
              </div>
            </div>

            <div>
              <label class="label">Phone Number *</label>
              <input type="tel" name="phone" class="input text-sm" placeholder="+91 XXXXX XXXXX" required pattern="[0-9+\-\s]+" />
            </div>

            <div>
              <label class="label">Email Address</label>
              <input type="email" name="email" class="input text-sm" placeholder="ravi@example.com" />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="label">Moving From *</label>
                <input type="text" name="from_city" class="input text-sm" placeholder="City / Area" required />
              </div>
              <div>
                <label class="label">Moving To *</label>
                <input type="text" name="to_city" class="input text-sm" placeholder="City / Area" required />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="label">Move Type *</label>
                <select name="move_type" class="select text-sm" required>
                  <option value="">Select type</option>
                  <option>Household Shifting</option>
                  <option>Office Relocation</option>
                  <option>Car Transport</option>
                  <option>Bike Transport</option>
                  <option>Warehouse Storage</option>
                  <option>International Moving</option>
                </select>
              </div>
              <div>
                <label class="label">Home / Office Size</label>
                <select name="property_size" class="select text-sm">
                  <option value="">Select size</option>
                  <option>1 BHK</option>
                  <option>2 BHK</option>
                  <option>3 BHK</option>
                  <option>4 BHK+</option>
                  <option>Villa / Independent</option>
                  <option>Office Space</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="label">Preferred Date</label>
                <input type="date" name="move_date" class="input text-sm" />
              </div>
              <div>
                <label class="label">Preferred Time</label>
                <select name="move_time" class="select text-sm">
                  <option value="">Any time</option>
                  <option>Morning (6 AM – 12 PM)</option>
                  <option>Afternoon (12 PM – 5 PM)</option>
                  <option>Evening (5 PM – 9 PM)</option>
                </select>
              </div>
            </div>

            <div>
              <label class="label">Special Requirements / Items</label>
              <textarea name="requirements" class="input text-sm h-24 resize-none" placeholder="e.g., piano, aquarium, antique furniture, car, etc."></textarea>
            </div>

            <button type="submit" class="btn-primary w-full py-4 text-base rounded-xl">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              Submit Quote Request
            </button>
            <p class="text-center text-xs text-warm-400">🔒 Secure. Private. No spam. We'll respond within 30 minutes.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
