---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CONTACT } from '../data/cities';
---

<BaseLayout
  title="Page Not Found | PackersHub"
  description="The page you're looking for doesn't exist. Find our services or contact PackersHub at +917731074075."
  noindex={true}
>
  <Header slot="header" />

  <section class="min-h-[70vh] flex items-center bg-hero-gradient">
    <div class="container text-center">
      <div class="font-display text-[120px] md:text-[160px] text-brand-200 leading-none font-bold reveal">404</div>
      <h1 class="font-display text-h2 text-warm-950 mb-4 reveal reveal-delay-1">Page Not Found</h1>
      <p class="text-warm-600 text-body-lg mb-8 max-w-md mx-auto reveal reveal-delay-2">The page you're looking for has moved or doesn't exist. Let us help you find what you need.</p>

      <div class="flex flex-wrap gap-3 justify-center mb-10 reveal reveal-delay-3">
        <a href="/" class="btn-primary-lg">Go to Homepage</a>
        <a href="/get-quote/" class="btn-outline px-8 py-4 text-base rounded-2xl">Get Free Quote</a>
      </div>

      <div class="flex flex-wrap justify-center gap-4 text-sm reveal reveal-delay-4">
        {[
          ['Services', '/services/'],
          ['About Us', '/about/'],
          ['Blog', '/blog/'],
          ['Contact', '/contact/'],
        ].map(([label, href]) => (
          <a href={href} class="text-brand-600 hover:underline">{label}</a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
