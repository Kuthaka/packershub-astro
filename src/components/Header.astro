---
// src/components/Header.astro
import { CONTACT, BUSINESS, states } from '../data/cities';
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-warm-100 transition-shadow duration-300">
  <!-- Top Bar -->
  <div class="bg-brand-500 text-white py-1.5 px-4 text-xs">
    <div class="container flex items-center justify-between gap-4 flex-wrap">
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        BV Nagar, Nellore, AP 524004
      </span>
      <div class="flex items-center gap-4">
        <a href={CONTACT.callLink} class="flex items-center gap-1.5 font-semibold hover:text-brand-100 transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          {CONTACT.phoneDisplay}
        </a>
        <span class="hidden sm:inline text-brand-200">|</span>
        <span class="hidden sm:flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Mon–Sun: 6 AM – 10 PM
        </span>
      </div>
    </div>
  </div>

  <!-- Main Nav -->
  <div class="container">
    <nav class="flex items-center justify-between h-16 gap-4">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 flex-shrink-0 group">
        <img src="/logo.svg" alt="PackersHub Logo" class="w-10 h-10 object-contain" />
        <div>
          <span class="block font-display text-xl text-warm-950 group-hover:text-brand-600 transition-colors leading-none">PackersHub</span>
          <span class="block text-[10px] text-warm-500 font-medium tracking-wide leading-none mt-0.5">South India's Trusted Movers</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden lg:flex items-center gap-1">
        <li>
          <a href="/" class={`btn-ghost text-sm ${isActive('/') && currentPath === '/' ? 'text-brand-600 font-semibold' : ''}`}>Home</a>
        </li>
        <li>
          <a href="/services/" class={`btn-ghost text-sm ${isActive('/services') ? 'text-brand-600 font-semibold' : ''}`}>Services</a>
        </li>

        <!-- States Dropdown -->
        <li class="relative group">
          <button class="btn-ghost text-sm flex items-center gap-1">
            States
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-64 bg-white rounded-2xl shadow-float border border-warm-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 p-2 z-50">
            {Object.values(states).map(state => (
              <a href={`/${state.slug}/`} class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-brand-50 transition-colors">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-xs font-bold" style={`background:${state.color}`}>{state.code}</div>
                <div>
                  <div class="text-sm font-semibold text-warm-900">{state.name}</div>
                  <div class="text-xs text-warm-500">{state.cities} cities</div>
                </div>
              </a>
            ))}
          </div>
        </li>

        <li>
          <a href="/blog/" class={`btn-ghost text-sm ${isActive('/blog') ? 'text-brand-600 font-semibold' : ''}`}>Blog</a>
        </li>
        <li>
          <a href="/about/" class={`btn-ghost text-sm ${isActive('/about') ? 'text-brand-600 font-semibold' : ''}`}>About</a>
        </li>
        <li>
          <a href="/contact/" class={`btn-ghost text-sm ${isActive('/contact') ? 'text-brand-600 font-semibold' : ''}`}>Contact</a>
        </li>
      </ul>

      <!-- CTA Buttons -->
      <div class="hidden md:flex items-center gap-2">
        <a href={CONTACT.whatsappLink()} target="_blank" rel="noopener" class="btn-whatsapp text-xs px-4 py-2.5 rounded-xl">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <a href="/get-quote/" class="btn-primary text-xs px-4 py-2.5 rounded-xl">Get Free Quote</a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-xl hover:bg-warm-100 transition-colors" aria-label="Open menu">
        <svg id="menu-icon" class="w-6 h-6 text-warm-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-warm-100 bg-white">
    <div class="container py-4 space-y-1">
      <a href="/" class="block px-4 py-3 rounded-xl hover:bg-brand-50 text-sm font-medium text-warm-800">Home</a>
      <a href="/services/" class="block px-4 py-3 rounded-xl hover:bg-brand-50 text-sm font-medium text-warm-800">Services</a>
      <div class="px-4 py-2 text-xs font-bold text-warm-400 uppercase tracking-widest mt-2">States</div>
      {Object.values(states).map(state => (
        <a href={`/${state.slug}/`} class="flex items-center gap-3 px-4 py-2.5 rounded-xl hover:bg-brand-50 text-sm font-medium text-warm-800">
          <span class="w-6 h-6 rounded text-white text-[10px] font-bold flex items-center justify-center" style={`background:${state.color}`}>{state.code}</span>
          {state.name}
        </a>
      ))}
      <a href="/blog/" class="block px-4 py-3 rounded-xl hover:bg-brand-50 text-sm font-medium text-warm-800">Blog</a>
      <a href="/about/" class="block px-4 py-3 rounded-xl hover:bg-brand-50 text-sm font-medium text-warm-800">About</a>
      <a href="/contact/" class="block px-4 py-3 rounded-xl hover:bg-brand-50 text-sm font-medium text-warm-800">Contact</a>
      <div class="flex gap-2 px-2 pt-3 border-t border-warm-100">
        <a href="tel:+917731074075" class="btn-outline flex-1 text-xs py-2.5 rounded-xl">📞 Call Now</a>
        <a href="/get-quote/" class="btn-primary flex-1 text-xs py-2.5 rounded-xl">Free Quote</a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-[96px]"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
